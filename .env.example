# VITE_GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_ANTHROPIC_API_KEY: Claude Haiku による AI 相性分析・曲提案に使用する。
# WARNING: ブラウザバンドルに含まれるためデモ用途限定。本番はサーバーサイドプロキシを使うこと。
VITE_ANTHROPIC_API_KEY="sk-ant-..."

# VITE_SPOTIFY_CLIENT_ID: Spotify OAuth PKCE フロー用のクライアントID。
# Spotify Developer Dashboard で取得し、リダイレクトURIにデプロイ先のオリジンを登録すること。
VITE_SPOTIFY_CLIENT_ID="YOUR_SPOTIFY_CLIENT_ID"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
